# Khukra Logistics — copy to .env (optional; start-dev writes frontend/.env.local)
# API port (default 8010)
KHUKRA_LOGISTICS_API_PORT=8010
# UI port (default 3020)
KHUKRA_LOGISTICS_UI_PORT=3020
# Backend URL used by Next.js API proxy
KHUKRA_LOGISTICS_API_URL=http://127.0.0.1:8010
NEXT_PUBLIC_API_URL=http://127.0.0.1:8010
# Local data root (default: ./data)
# KHUKRA_LOGISTICS_DATA_ROOT=
